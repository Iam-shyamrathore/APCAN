# Environment Configuration
ENVIRONMENT=development
DEBUG=True

# API Configuration
API_URL=http://localhost:8000

# CORS - Comma-separated list
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/database
# Use Neon for FREE tier with scale-to-zero
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/apcan_dev
DB_ECHO=False

# Security - CRITICAL: Change these in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_MINIMUM_32_CHARACTERS_REQUIRED_USE_OPENSSL_RAND
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google APIs
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Google Calendar (Optional - for appointment scheduling)
# Path to service account JSON file
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Redis (Session State)
# Use Redis Cloud FREE tier: https://redis.com/try-free/
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# ============================================
# COST-FREE SETUP GUIDE
# ============================================
#
# 1. DATABASE - Neon PostgreSQL (FREE)
#    - Sign up: https://neon.tech
#    - Create project → Get connection string
#    - FREE tier: 0.5GB storage, scale-to-zero compute
#
# 2. GOOGLE GEMINI API (FREE)
#    - Get API key: https://aistudio.google.com/app/apikey
#    - FREE tier: 1,500 requests/day, 15 RPM
#
# 3. REDIS - Redis Cloud (FREE)
#    - Sign up: https://redis.com/try-free/
#    - Create database → Get connection string
#    - FREE tier: 30MB memory
#
# 4. GOOGLE CALENDAR (OPTIONAL - FREE)
#    - Create service account in Google Cloud Console
#    - Enable Calendar API
#    - Download JSON key file
#
# ============================================
# PRODUCTION SECURITY CHECKLIST
# ============================================
# [ ] Change SECRET_KEY to random 32+ character string
# [ ] Set ENVIRONMENT=production
# [ ] Set DEBUG=False
# [ ] Use strong database password
# [ ] Enable SSL/TLS for database (Neon includes this)
# [ ] Restrict CORS_ORIGINS to your domain only
# [ ] Rotate secrets regularly
# [ ] Never commit .env file to git
